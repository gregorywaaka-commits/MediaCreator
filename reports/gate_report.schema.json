{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GateReport",
  "type": "object",
  "required": [
    "request_id",
    "policy_version",
    "release_class",
    "decision",
    "decision_reasons",
    "gate_results",
    "timestamp_utc"
  ],
  "properties": {
    "request_id": { "type": "string" },
    "policy_version": { "type": "string" },
    "release_class": {
      "type": "string",
      "enum": ["open", "licensed", "protected"]
    },
    "decision": {
      "type": "string",
      "enum": ["pass", "hold", "warn", "block_release"]
    },
    "decision_reasons": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "gate_results": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "enum": ["pass", "warn", "fail", "skip"]
      }
    },
    "break_glass": {
      "type": "object",
      "required": ["used"],
      "properties": {
        "used": { "type": "boolean" },
        "approved_by": { "type": "string" },
        "ticket_id": { "type": "string" },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
