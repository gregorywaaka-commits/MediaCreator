{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GoldenVectors",
  "type": "object",
  "required": ["version", "cases"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "release_class", "signals", "expected"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "release_class": {
            "type": "string",
            "enum": ["open", "licensed", "protected"]
          },
          "signals": {
            "type": "object",
            "required": ["missing_docs", "compliance_fail", "watermark_fail_twice", "quality_pass"],
            "properties": {
              "missing_docs": { "type": "boolean" },
              "compliance_fail": { "type": "boolean" },
              "watermark_fail_twice": { "type": "boolean" },
              "quality_pass": { "type": "boolean" }
            },
            "additionalProperties": false
          },
          "expected": {
            "type": "object",
            "required": ["decision", "reason_codes_contains"],
            "properties": {
              "decision": {
                "type": "string",
                "enum": ["pass", "hold", "warn", "block_release"]
              },
              "reason_codes_contains": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
